{
  "name": "skalex",
  "version": "4.0.0-alpha.5",
  "minVersion": "4.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "AI-first · Isomorphic · Zero-dependency · Local-first JavaScript database.",
  "keywords": [
    "skalex",
    "database",
    "db",
    "document",
    "collections",
    "ai",
    "ai-first",
    "vector",
    "embeddings",
    "semantic-search",
    "agent-memory",
    "mcp",
    "model-context-protocol",
    "local-first",
    "offline",
    "isomorphic",
    "browser",
    "edge",
    "zero-dependency",
    "node",
    "bun",
    "deno",
    "json",
    "file-based"
  ],
  "author": {
    "name": "Tarek Raafat",
    "email": "tarek.m.raafat@gmail.com"
  },
  "homepage": "https://github.com/TarekRaafat/skalex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TarekRaafat/skalex.git"
  },
  "bugs": {
    "url": "https://github.com/TarekRaafat/skalex/issues"
  },
  "main": "./dist/skalex.cjs",
  "module": "./dist/skalex.esm.js",
  "browser": "./dist/skalex.browser.js",
  "jsdelivr": "./dist/skalex.umd.min.js",
  "unpkg": "./dist/skalex.umd.min.js",
  "types": "./dist/skalex.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/skalex.browser.js",
      "import": "./dist/skalex.esm.js",
      "require": "./dist/skalex.cjs",
      "types": "./dist/skalex.d.ts"
    },
    "./min": {
      "browser": "./dist/skalex.browser.js",
      "import": "./dist/skalex.esm.min.js",
      "require": "./dist/skalex.min.cjs",
      "types": "./dist/skalex.d.ts"
    },
    "./connectors": {
      "import": "./src/connectors/index.js"
    },
    "./connectors/storage": {
      "import": "./src/connectors/storage/index.js"
    },
    "./connectors/embedding": {
      "import": "./src/connectors/embedding/index.js"
    },
    "./connectors/llm": {
      "import": "./src/connectors/llm/index.js"
    },
    "./connectors/fs": {
      "import": "./src/connectors/storage/fs.js"
    },
    "./connectors/encrypted": {
      "import": "./src/connectors/storage/encrypted.js"
    },
    "./connectors/local": {
      "import": "./src/connectors/storage/local.js"
    },
    "./connectors/d1": {
      "import": "./src/connectors/storage/d1.js"
    },
    "./connectors/bun-sqlite": {
      "import": "./src/connectors/storage/bun-sqlite.js"
    },
    "./connectors/libsql": {
      "import": "./src/connectors/storage/libsql.js"
    }
  },
  "files": [
    "dist",
    "src/connectors",
    "src/engine/errors.js"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "node scripts/verify-node-stubs.mjs && rollup -c && cp src/index.d.ts dist/skalex.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "deps:check": "madge --circular src/",
    "types:check": "tsd",
    "verify:stubs": "node scripts/verify-node-stubs.mjs",
    "verify": "npm run test && npm run build && npm run lint && npm run deps:check && npm run types:check",
    "smoke:node": "node tests/smoke/node.test.cjs",
    "smoke:bun": "bun tests/smoke/bun.test.js && bun tests/smoke/bun-sqlite.test.js",
    "smoke:deno": "deno run tests/smoke/deno.test.js",
    "smoke:browser": "node tests/smoke/browser.test.js",
    "smoke": "npm run smoke:node && npm run smoke:bun && npm run smoke:deno && npm run smoke:browser",
    "test:all": "npm run verify && npm run smoke"
  },
  "tsd": {
    "directory": "tests/types"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "contributors": [
    {
      "name": "Tarek Raafat",
      "email": "tarek.m.raafat@gmail.com"
    }
  ],
  "maintainers": [
    {
      "name": "Tarek Raafat",
      "email": "tarek.m.raafat@gmail.com"
    }
  ],
  "sideEffects": false,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "madge": "^8.0.0",
    "playwright": "^1.59.1",
    "rollup": "^4.60.1",
    "tsd": "^0.33.0",
    "vitest": "^4.1.4"
  }
}
