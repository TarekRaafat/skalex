{
  "name": "skalex",
  "version": "4.0.0-alpha",
  "license": "Apache-2.0",
  "description": "AI-first · Isomorphic · Zero-dependency · Local-first JavaScript database.",
  "keywords": [
    "skalex",
    "database",
    "db",
    "document",
    "collections",
    "ai",
    "ai-first",
    "vector",
    "embeddings",
    "semantic-search",
    "agent-memory",
    "mcp",
    "model-context-protocol",
    "local-first",
    "offline",
    "isomorphic",
    "browser",
    "edge",
    "zero-dependency",
    "node",
    "bun",
    "deno",
    "json",
    "file-based"
  ],
  "author": {
    "name": "Tarek Raafat",
    "email": "tarek.m.raafat@gmail.com"
  },
  "homepage": "https://github.com/TarekRaafat/skalex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TarekRaafat/skalex.git"
  },
  "bugs": {
    "url": "https://github.com/TarekRaafat/skalex/issues"
  },
  "main": "./dist/skalex.cjs.js",
  "module": "./dist/skalex.esm.js",
  "types": "./dist/skalex.d.ts",
  "exports": {
    ".": {
      "import": "./dist/skalex.esm.js",
      "require": "./dist/skalex.cjs.js",
      "types": "./dist/skalex.d.ts"
    },
    "./min": {
      "import": "./dist/skalex.esm.min.js",
      "require": "./dist/skalex.cjs.min.js",
      "types": "./dist/skalex.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c && cp src/index.d.ts dist/skalex.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "contributors": [
    {
      "name": "Tarek Raafat",
      "email": "tarek.m.raafat@gmail.com"
    }
  ],
  "maintainers": [
    {
      "name": "Tarek Raafat",
      "email": "tarek.m.raafat@gmail.com"
    }
  ],
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "jest": "^29.5.0",
    "rollup": "^4.60.0",
    "vitest": "^4.1.2"
  }
}
